-- Task Manager
local RunningTasks = {}
local Unloaded = false

local function RunScript(url)
    if Unloaded then return end

    local thread = task.spawn(function()
        if not Unloaded then
            loadstring(game:HttpGet(url))()
        end
    end)

    table.insert(RunningTasks, thread)
end

-- UI Library
local Library = loadstring(game:HttpGet("https://raw.githubusercontent.com/xHeptc/Kavo-UI-Library/main/source.lua"))()
local Window = Library.CreateLib("val", "DarkTheme")

-- MAIN TAB
local Main = Window:NewTab("val")
local MainSection = Main:NewSection("FPS universal")

MainSection:NewButton("LegitBot", "Legit Aimbot", function()
    RunScript("https://raw.githubusercontent.com/n-xz/LegitBot/refs/heads/main/LegitBot")
end)

MainSection:NewButton("BlatantBot", "Blatant Aimbot", function()
    RunScript("https://raw.githubusercontent.com/n-xz/.../refs/heads/main/BlatantBot")
end)

-- UNIVERSAL SECTION
local valSection = Main:NewSection("universal")

valSection:NewButton("TCESP", "Team Check Esp", function()
    RunScript("https://raw.githubusercontent.com/n-xz/.../refs/heads/main/TCESP")
end)

valSection:NewButton("RevampedHBE", "A Revamp of an HBE script", function()
    RunScript("https://raw.githubusercontent.com/n-xz/.../refs/heads/main/RevampedHBE")
end)

valSection:NewButton("LegitHBE", "A Legit Revamp of an HBE script", function()
    RunScript("https://raw.githubusercontent.com/n-xz/.../refs/heads/main/LegitHBE")
end)

-- UI TAB
local Settings = Window:NewTab("UI")
local SettingsSection = Settings:NewSection("UI")

SettingsSection:NewKeybind("Toggle", "Toggles the Gui", Enum.KeyCode.RightControl, function()
    if not Unloaded then
        Library:ToggleUI()
    end
end)

SettingsSection:NewButton("Unload Script", "Stops everything and closes the UI", function()

    Unloaded = true

    -- Cancel running tasks
    for _,thread in pairs(RunningTasks) do
        pcall(function()
            task.cancel(thread)
        end)
    end

    -- Destroy GUI
    for _,v in pairs(game.CoreGui:GetChildren()) do
        if v.Name == "val" then
            v:Destroy()
        end
    end

    game.StarterGui:SetCore("SendNotification", {
        Title = "val";
        Text = "Script Unloaded";
        Duration = 0.5;
    })

end)
